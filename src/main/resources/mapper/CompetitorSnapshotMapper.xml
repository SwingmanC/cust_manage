<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.custmanage.server.mapper.CompetitorSnapshotMapper">

    <resultMap id="SnapshotMap" type="com.custmanage.server.mapper.CompetitorSnapshotMapper$CompetitorSnapshotEntity">
        <id property="id" column="id"/>
        <result property="ticketId" column="ticket_id"/>
        <result property="competitorRecordId" column="competitor_record_id"/>
        <result property="groupId" column="group_id"/>
        <result property="changeType" column="change_type"/>
        <result property="beforeServiceId" column="before_service_id"/>
        <result property="afterServiceId" column="after_service_id"/>
        <result property="beforeCompetitorName" column="before_competitor_name"/>
        <result property="afterCompetitorName" column="after_competitor_name"/>
        <result property="beforeQuantity" column="before_quantity"/>
        <result property="afterQuantity" column="after_quantity"/>
        <result property="beforeStatMonth" column="before_stat_month"/>
        <result property="afterStatMonth" column="after_stat_month"/>
        <result property="beforeRemark" column="before_remark"/>
        <result property="afterRemark" column="after_remark"/>
    </resultMap>

    <insert id="insert">
        INSERT INTO szzw.t_yqyc_wf_ticket_competitor_snapshot
            (id, ticket_id, competitor_record_id, group_id, change_type,
             before_service_id, after_service_id,
             before_competitor_name, after_competitor_name,
             before_quantity, after_quantity,
             before_stat_month, after_stat_month,
             before_remark, after_remark, created_by, created_time)
        VALUES (#{id}, #{ticketId}, #{competitorRecordId}, #{groupId}, #{changeType},
                #{beforeServiceId}, #{afterServiceId},
                #{beforeCompetitorName}, #{afterCompetitorName},
                #{beforeQuantity}, #{afterQuantity},
                #{beforeStatMonth}, #{afterStatMonth},
                #{beforeRemark}, #{afterRemark}, NULL, SYSDATE)
    </insert>

    <select id="selectByTicketId" resultMap="SnapshotMap">
        SELECT * FROM szzw.t_yqyc_wf_ticket_competitor_snapshot WHERE ticket_id = #{ticketId}
    </select>
</mapper>

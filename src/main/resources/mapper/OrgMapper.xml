<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.custmanage.server.mapper.OrgMapper">

    <resultMap id="OrgEntityMap" type="com.custmanage.server.mapper.OrgMapper$OrgEntity">
        <id property="id" column="id"/>
        <result property="orgCode" column="org_code"/>
        <result property="orgName" column="org_name"/>
        <result property="parentId" column="parent_id"/>
        <result property="orgType" column="org_type"/>
        <result property="orgPath" column="org_path"/>
    </resultMap>

    <select id="selectById" resultMap="OrgEntityMap">
        SELECT id, org_code, org_name, parent_id, org_type, org_path
        FROM szzw.t_yqyc_sys_org
        WHERE id = #{orgId}
    </select>

    <select id="selectOrgIdsByPathPrefix" resultType="long">
        SELECT id
        FROM szzw.t_yqyc_sys_org
        WHERE org_path LIKE #{orgPathPrefix} || '%'
          AND status = '启用'
    </select>

</mapper>

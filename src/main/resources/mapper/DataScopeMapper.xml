<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.custmanage.server.mapper.DataScopeMapper">

    <resultMap id="DataScopeEntityMap" type="com.custmanage.server.mapper.DataScopeMapper$DataScopeEntity">
        <id property="id" column="id"/>
        <result property="roleId" column="role_id"/>
        <result property="scopeType" column="scope_type"/>
        <result property="scopeOrgId" column="scope_org_id"/>
        <result property="scopeGroupId" column="scope_group_id"/>
    </resultMap>

    <select id="selectByRoleIds" resultMap="DataScopeEntityMap">
        SELECT id, role_id, scope_type, scope_org_id, scope_group_id
        FROM sys_data_scope
        WHERE role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.custmanage.server.mapper.BizServiceMapper">

    <select id="selectAll" resultType="com.custmanage.server.vo.BizServiceVO">
        SELECT id                                          AS serviceId,
        service_code                                AS serviceCode,
        service_name || ' (' || service_measure || ')' AS serviceName
        FROM szzw.t_yqyc_biz_service
        <where>
            <if test="status != null and status != ''">
                status = #{status}
            </if>
        </where>
        ORDER BY sort_no, id ASC
    </select>
</mapper>
